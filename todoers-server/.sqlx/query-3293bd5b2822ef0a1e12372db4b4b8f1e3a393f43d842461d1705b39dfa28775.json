  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                u.member_id as \"member_id: MemberId\",\n                u.identity_pub AS \"identity_pub: X25519Pub\",\n                u.signing_pub AS \"signing_pub: Ed25519Pub\",\n                m.role AS \"role: Role\"\n            FROM list_members m\n            JOIN users u ON u.member_id = m.member_id\n            WHERE m.list_id = $1\n            ORDER BY m.added_at\n            ",
