  "query": "\n            SELECT\n                seq,\n                epoch,\n                author AS \"author: MemberId\",\n                nonce AS \"nonce: Nonce\",\n                ciphertext,\n                signature AS \"signature: Signature\"\n            FROM updates\n            WHERE list_id = $1 AND seq > $2\n            ORDER BY seq\n            LIMIT $3\n            ",
