  "query": "\n            SELECT u.member_id, u.identity_pub, u.signing_pub, m.role AS \"role: Role\"\n            FROM list_members m\n            JOIN users u ON u.member_id = m.member_id\n            WHERE m.list_id = $1\n            ORDER BY m.added_at\n            ",
