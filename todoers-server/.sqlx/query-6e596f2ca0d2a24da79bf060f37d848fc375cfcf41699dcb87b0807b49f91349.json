  "query": "\n            SELECT\n                device_id AS \"device_id: DeviceId\",\n                label,\n                created_at,\n                revoked_at IS NOT NULL AS \"revoked!\"\n            FROM trusted_device_keys\n            WHERE member_id = $1\n            ORDER BY created_at\n            ",
